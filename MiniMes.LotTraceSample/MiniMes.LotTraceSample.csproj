  <ItemGroup>
    <None Include="App.config" />
  </ItemGroup>

  <Target Name="CopyManualAppConfig" AfterTargets="Build">
    <Copy SourceFiles="App.config" DestinationFiles="$(TargetDir)$(TargetFileName).config" OverwriteReadOnlyFiles="true" />
  </Target>
</Project>
