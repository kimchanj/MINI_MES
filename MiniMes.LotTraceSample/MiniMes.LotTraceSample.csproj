      <Private>true</Private>
    </Reference>
    <Reference Include="DevExpress.XtraGrid.v25.2">
      <HintPath>$(USERPROFILE)\.nuget\packages\devexpress.win.grid\25.2.5\lib\net462\DevExpress.XtraGrid.v25.2.dll</HintPath>
      <Private>true</Private>
